{% doc %}
  @prompt
    Enhance the existing premium logo scroller section with the following improvements:
    - Smooth infinite marquee animation with configurable speed
    - Pause on hover effect
    - Logos displayed in grayscale by default, transitioning to full color on hover
    - Soft fade/gradient edges on left and right sides to create a seamless look
    - Adjustable logo size and spacing between logos
    - Optional dual-row scrolling (second row scrolling in reverse direction)
    - Clean background with subtle padding and optional border or divider lines above/below
    - Fully responsive and mobile-friendly
    - Accessible (respects prefers-reduced-motion)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-scroller-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
    position: relative;
    overflow: hidden;
    {% if block.settings.show_top_border %}
      border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
    {% if block.settings.show_bottom_border %}
      border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-logo-scroller__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-logo-scroller__track-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.logo_spacing }}px;
    width: fit-content;
    animation: ai-logo-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-logo-scroller__track-{{ ai_gen_id }} {
      animation: none;
    }
  }

  .ai-logo-scroller__track-{{ ai_gen_id }}:hover {
    {% if block.settings.pause_on_hover %}
      animation-play-state: paused;
    {% endif %}
  }

  .ai-logo-scroller__track--reverse-{{ ai_gen_id }} {
    animation-direction: reverse;
  }

  .ai-logo-scroller__row-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-logo-scroller__row-{{ ai_gen_id }}:not(:last-child) {
    margin-bottom: {{ block.settings.row_spacing }}px;
  }

  .ai-logo-scroller__item-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-logo-scroller__image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    {% if block.settings.grayscale_default %}
      filter: grayscale(100%);
      opacity: {{ block.settings.grayscale_opacity }};
      transition: filter 0.3s ease, opacity 0.3s ease;
    {% endif %}
  }

  {% if block.settings.grayscale_default %}
    .ai-logo-scroller__item-{{ ai_gen_id }}:hover .ai-logo-scroller__image-{{ ai_gen_id }} {
      filter: grayscale(0%);
      opacity: 1;
    }
  {% endif %}

  .ai-logo-scroller__fade-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    bottom: 0;
    width: {{ block.settings.fade_width }}px;
    pointer-events: none;
    z-index: 2;
  }

  .ai-logo-scroller__fade--left-{{ ai_gen_id }} {
    left: 0;
    background: linear-gradient(to right, {{ block.settings.background_color }}, transparent);
  }

  .ai-logo-scroller__fade--right-{{ ai_gen_id }} {
    right: 0;
    background: linear-gradient(to left, {{ block.settings.background_color }}, transparent);
  }

  @keyframes ai-logo-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-logo-scroller__item-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.7 }}px;
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }

    .ai-logo-scroller__track-{{ ai_gen_id }} {
      gap: {{ block.settings.logo_spacing | times: 0.7 }}px;
    }
  }
{% endstyle %}

<logo-scroller-{{ ai_gen_id }} class="ai-logo-scroller-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-scroller__wrapper-{{ ai_gen_id }}">
    {% liquid
      assign logo_count = 0
      for i in (1..12)
        assign logo_key = 'logo_' | append: i
        if block.settings[logo_key] != blank
          assign logo_count = logo_count | plus: 1
        endif
      endfor
    %}

    {% if logo_count > 0 %}
      <div class="ai-logo-scroller__row-{{ ai_gen_id }}">
        <div class="ai-logo-scroller__track-{{ ai_gen_id }}">
          {% for i in (1..12) %}
            {% liquid
              assign logo_key = 'logo_' | append: i
              assign logo = block.settings[logo_key]
            %}
            {% if logo != blank %}
              <div class="ai-logo-scroller__item-{{ ai_gen_id }}">
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ logo.alt | escape }}"
                  loading="lazy"
                  width="400"
                  height="400"
                  class="ai-logo-scroller__image-{{ ai_gen_id }}"
                >
              </div>
            {% endif %}
          {% endfor %}
          {% for i in (1..12) %}
            {% liquid
              assign logo_key = 'logo_' | append: i
              assign logo = block.settings[logo_key]
            %}
            {% if logo != blank %}
              <div class="ai-logo-scroller__item-{{ ai_gen_id }}">
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ logo.alt | escape }}"
                  loading="lazy"
                  width="400"
                  height="400"
                  class="ai-logo-scroller__image-{{ ai_gen_id }}"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>
        {% if block.settings.show_fade %}
          <div class="ai-logo-scroller__fade-{{ ai_gen_id }} ai-logo-scroller__fade--left-{{ ai_gen_id }}"></div>
          <div class="ai-logo-scroller__fade-{{ ai_gen_id }} ai-logo-scroller__fade--right-{{ ai_gen_id }}"></div>
        {% endif %}
      </div>

      {% if block.settings.enable_dual_row %}
        <div class="ai-logo-scroller__row-{{ ai_gen_id }}">
          <div class="ai-logo-scroller__track-{{ ai_gen_id }} ai-logo-scroller__track--reverse-{{ ai_gen_id }}">
            {% for i in (1..12) %}
              {% liquid
                assign logo_key = 'logo_' | append: i
                assign logo = block.settings[logo_key]
              %}
              {% if logo != blank %}
                <div class="ai-logo-scroller__item-{{ ai_gen_id }}">
                  <img
                    src="{{ logo | image_url: width: 400 }}"
                    alt="{{ logo.alt | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                    class="ai-logo-scroller__image-{{ ai_gen_id }}"
                  >
                </div>
              {% endif %}
            {% endfor %}
            {% for i in (1..12) %}
              {% liquid
                assign logo_key = 'logo_' | append: i
                assign logo = block.settings[logo_key]
              %}
              {% if logo != blank %}
                <div class="ai-logo-scroller__item-{{ ai_gen_id }}">
                  <img
                    src="{{ logo | image_url: width: 400 }}"
                    alt="{{ logo.alt | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                    class="ai-logo-scroller__image-{{ ai_gen_id }}"
                  >
                </div>
              {% endif %}
            {% endfor %}
          </div>
          {% if block.settings.show_fade %}
            <div class="ai-logo-scroller__fade-{{ ai_gen_id }} ai-logo-scroller__fade--left-{{ ai_gen_id }}"></div>
            <div class="ai-logo-scroller__fade-{{ ai_gen_id }} ai-logo-scroller__fade--right-{{ ai_gen_id }}"></div>
          {% endif %}
        </div>
      {% endif %}
    {% else %}
      <div style="text-align: center; padding: 60px 20px; color: #999;">
        Add logos to display in the scroller
      </div>
    {% endif %}
  </div>
</logo-scroller-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoScroller{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
        
        if (prefersReducedMotion.matches) {
          const tracks = this.querySelectorAll('.ai-logo-scroller__track-{{ ai_gen_id }}');
          tracks.forEach(track => {
            track.style.animation = 'none';
          });
        }
      }
    }

    customElements.define('logo-scroller-{{ ai_gen_id }}', LogoScroller{{ ai_gen_id }});
  })();
</script>

