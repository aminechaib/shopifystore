<header class="custom-header">
  
  <!-- LEFT: Navigation Links -->
  <nav class="header-nav">
    {%- for link in linklists['main-menu'].links -%}
      <a href="{{ link.url }}" class="nav-link">{{ link.title }}</a>
    {%- endfor -%}
  </nav>

  <!-- CENTER: Logo / Brand Name -->
  <div class="header-logo">
    <a href="{{ routes.root_url }}">{{ shop.name }}</a>
  </div>

  <!-- RIGHT: Account & Cart -->
  <div class="header-actions">
    {%- if shop.customer_accounts_enabled -%}
      <a href="{{ routes.account_url }}" class="nav-link">Account</a>
    {%- endif -%}
    <a href="{{ routes.cart_url }}" class="nav-link">
      Cart [<span id="cart-count">{{ cart.item_count }}</span>]
    </a>
  </div>

</header>

<style>
  /* Hardcoded CSS - This layout will never break or shift */
  .custom-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px;
    background-color: #ffffff;
    border-bottom: 1px solid #000000;
    font-family: 'Helvetica Neue', Helvetica, sans-serif;
  }

  .header-nav, .header-actions {
    display: flex;
    gap: 30px;
    flex: 1; /* Forces equal width so the logo stays perfectly centered */
  }

  .header-actions {
    justify-content: flex-end;
  }

  .header-logo {
    flex: 1;
    text-align: center;
  }

  .header-logo a {
    font-size: 24px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    color: #000;
  }

  .nav-link {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    color: #000;
    transition: opacity 0.2s ease;
  }

  .nav-link:hover {
    opacity: 0.5;
  }
</style>

{% schema %}
{
  "name": "Custom Header",
  "settings": []
}
{% endschema %}
