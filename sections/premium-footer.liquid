{%- style -%}
  {%- if section.settings.page_width == 'full' -%}
    {%- assign max_w = '100%' -%}
  {%- elsif section.settings.page_width == 'wide' -%}
    {%- assign max_w = '1600px' -%}
  {%- else -%}
    {%- assign max_w = '1200px' -%}
  {%- endif -%}

  #PremiumFooter-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    
    --pf-bg: {{ section.settings.bg_color }};
    --pf-text: {{ section.settings.text_color }};
    --pf-text-muted: {{ section.settings.text_color | color_modify: 'alpha', 0.6 }};
    --pf-border: {{ section.settings.text_color | color_modify: 'alpha', 0.15 }};
    --pf-accent: {{ section.settings.accent_color }};
  }

  #PremiumFooter-{{ section.id }} .pf-container {
    max-width: {{ max_w }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.edge_spacing }}px {{ section.settings.padding_bottom }}px {{ section.settings.edge_spacing }}px;
    margin: 0 auto;
  }

  @media screen and (max-width: 768px) {
    #PremiumFooter-{{ section.id }} .pf-container {
      padding: calc({{ section.settings.padding_top }}px / 1.5) 1.5rem calc({{ section.settings.padding_bottom }}px / 1.5) 1.5rem;
    }
  }
{%- endstyle -%}

<footer class="premium-footer" id="PremiumFooter-{{ section.id }}">
  <div class="pf-container">
    
    <!-- Top Grid -->
    <div class="pf-grid">
      
      <!-- Column 1: Brand Info & Logo -->
      <div class="pf-column pf-brand-col">
        <div class="pf-brand">
          
          <!-- Aligned Logo Wrapper -->
          <div class="pf-title-wrapper">
            {%- if section.settings.logo != blank -%}
              {{ section.settings.logo | image_url: width: section.settings.logo_width | image_tag: class: 'pf-logo', loading: 'lazy', alt: shop.name, style: 'max-width: 100%; height: auto;' }}
            {%- else -%}
              <h3 class="pf-logo-text">{{ shop.name }}</h3>
            {%- endif -%}
          </div>
          
          {%- if section.settings.description != blank -%}
            <p class="pf-desc">{{ section.settings.description }}</p>
          {%- endif -%}
          
          <div class="pf-socials">
            {%- if section.settings.instagram != blank -%}
              <a href="{{ section.settings.instagram }}" target="_blank" class="pf-social-link" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.tiktok != blank -%}
              <a href="{{ section.settings.tiktok }}" target="_blank" class="pf-social-link" aria-label="TikTok">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.facebook != blank -%}
              <a href="{{ section.settings.facebook }}" target="_blank" class="pf-social-link" aria-label="Facebook">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Columns 2+: Menus & Newsletter -->
      {%- for block in section.blocks -%}
        <div class="pf-column" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            
            {%- when 'link_list' -%}
              <!-- Aligned Heading Wrapper -->
              <div class="pf-title-wrapper">
                <h4 class="pf-heading">{{ block.settings.heading }}</h4>
              </div>
              <ul class="pf-links">
                {%- for link in linklists[block.settings.menu].links -%}
                  <li>
                    <a href="{{ link.url }}" class="pf-link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>

            {%- when 'newsletter' -%}
              <!-- Aligned Heading Wrapper -->
              <div class="pf-title-wrapper">
                <h4 class="pf-heading">{{ block.settings.heading }}</h4>
              </div>
              <p class="pf-desc" style="margin-bottom: 1.5rem;">{{ block.settings.text }}</p>
              
              {%- form 'customer', id: 'PremiumFooterNewsletter', class: 'pf-newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="pf-input-group">
                  <label for="NewsletterEmail-{{ section.id }}" class="pf-visually-hidden">Email</label>
                  <input 
                    id="NewsletterEmail-{{ section.id }}"
                    type="email" 
                    name="contact[email]" 
                    class="pf-input" 
                    value="{{ form.email }}" 
                    placeholder="{{ block.settings.placeholder_text | default: 'Email address' }}" 
                    required
                  >
                  <button type="submit" class="pf-submit" aria-label="Subscribe">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </button>
                </div>
                {%- if form.posted_successfully? -%}
                  <p class="pf-success-msg">{{ block.settings.success_text | default: 'Thank you for subscribing!' }}</p>
                {%- endif -%}
              {%- endform -%}

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <!-- Bottom Bar -->
    <div class="pf-bottom">
      <div class="pf-bottom-inner">
        <p class="pf-copyright">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }} - {{ section.settings.copyright_text }}</p>
        <p class="pf-credits">Made with passion in Algeria • Built by AC</p>
        
        <!-- Payment Icons -->
        {%- if section.settings.show_payment_icons -%}
          <div class="pf-payments">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'pf-payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</footer>

<style>
  /* --- Premium Footer CSS --- */
  .premium-footer { 
    font-family: inherit; 
    border-top: 1px solid var(--pf-border);
  }
  
  /* Accessibility */
  .pf-visually-hidden {
    position: absolute !important;
    overflow: hidden;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    clip: rect(0 0 0 0);
    word-wrap: normal !important;
  }

  /* Flexbox Layout */
  .pf-grid { 
    display: flex; 
    flex-wrap: wrap;
    justify-content: space-between; 
    align-items: flex-start;
    gap: 3rem; 
  }
  
  .pf-column {
    flex: 1 1 200px;
  }

  .pf-brand-col {
    flex: 2 1 300px;
    max-width: 400px;
  }

  .pf-column:last-child {
    flex: 1.5 1 300px;
    max-width: 400px;
  }

  /* Alignment Wrapper for Logo and Headings */
  .pf-title-wrapper {
    display: flex;
    align-items: center;
    min-height: 40px; /* Ensures logo and text headings share the same baseline height */
    margin-bottom: 1.5rem;
  }

  /* Brand Info */
  .pf-logo { display: block; width: {{ section.settings.logo_width }}px; }
  .pf-logo-text { font-size: 1.5rem; font-weight: 700; margin: 0; text-transform: uppercase; letter-spacing: 0.05em; }
  .pf-desc { color: var(--pf-text-muted); line-height: 1.6; margin: 0 0 1.5rem 0; font-size: 0.95rem; }

  /* Socials */
  .pf-socials { display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .pf-social-link { 
    color: var(--pf-text); 
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), color 0.3s ease; 
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pf-social-link:hover, .pf-social-link:focus-visible { 
    color: var(--pf-accent); 
    transform: translateY(-4px) scale(1.05); 
    outline: none;
  }

  /* Headings */
  .pf-heading { 
    font-size: 1.05rem; 
    font-weight: 600; 
    margin: 0; 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
  }

  /* Links */
  .pf-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.8rem; }
  .pf-link { 
    color: var(--pf-text-muted); 
    text-decoration: none; 
    font-size: 0.95rem;
    transition: color 0.3s ease; 
    display: inline-block;
    position: relative;
    width: fit-content;
  }
  .pf-link::after {
    content: ''; position: absolute; bottom: -2px; left: 0; width: 100%; height: 1px;
    background: var(--pf-accent); transform: scaleX(0); transform-origin: right; transition: transform 0.4s ease;
  }
  .pf-link:hover, .pf-link:focus-visible { color: var(--pf-text); outline: none; }
  .pf-link:hover::after, .pf-link:focus-visible::after { transform: scaleX(1); transform-origin: left; }

  /* Newsletter */
  .pf-input-group {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--pf-border);
    padding-bottom: 0.5rem;
    transition: border-color 0.3s ease;
  }
  .pf-input-group:focus-within {
    border-bottom-color: var(--pf-text);
  }
  .pf-input {
    flex-grow: 1;
    background: transparent;
    border: none;
    color: var(--pf-text);
    font-size: 0.95rem;
    padding: 0.5rem 0;
    outline: none;
    font-family: inherit;
    box-shadow: none;
  }
  .pf-input::placeholder { color: var(--pf-text-muted); }
  .pf-submit {
    background: transparent;
    border: none;
    color: var(--pf-text);
    cursor: pointer;
    padding: 0.5rem;
    transition: transform 0.3s ease, color 0.3s ease;
    display: flex;
    align-items: center;
  }
  .pf-submit:hover, .pf-submit:focus-visible {
    transform: translateX(5px);
    color: var(--pf-accent);
    outline: none;
  }
  .pf-success-msg {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: #10B981;
  }

  /* Bottom Bar */
  .pf-bottom {
    border-top: 1px solid var(--pf-border);
    margin-top: 4rem;
    padding-top: 2rem;
  }
  .pf-bottom-inner {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .pf-bottom-inner { 
      flex-direction: row; 
      text-align: left;
    }
  }
  .pf-copyright {
    color: var(--pf-text-muted);
    font-size: 0.85rem;
    margin: 0;
  }
  .pf-credits {
    color: var(--pf-text-muted);
    font-size: 0.75rem;
    margin: 0;
    opacity: 0.6;
  }
  
  /* Payment Icons */
  .pf-payments {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
  .pf-payment-icon {
    width: 38px;
    height: 24px;
    opacity: 0.7;
    filter: grayscale(100%);
    transition: all 0.3s ease;
  }
  .pf-payment-icon:hover {
    opacity: 1;
    filter: grayscale(0%);
  }
</style>

{% schema %}
{
  "name": "Premium Footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Brand Info & Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50, "max": 300, "step": 5, "unit": "px",
      "label": "Logo Width",
      "default": 120
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand Description",
      "default": "Redefining modern essentials. Quality garments designed for everyday life."
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram Link"
    },
    {
      "type": "url",
      "id": "tiktok",
      "label": "TikTok Link"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Hover states)",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout & Sizing"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        { "value": "full", "label": "Full Width (100%)" },
        { "value": "wide", "label": "Wide (1600px)" },
        { "value": "standard", "label": "Standard (1200px)" }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "edge_spacing",
      "min": 0, "max": 100, "step": 2, "unit": "px",
      "label": "Distance from screen edges",
      "default": 40
    },
    {
      "type": "header",
      "content": "Spacing (Top & Bottom)"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Margin Top", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Margin Bottom", "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Padding Top", "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Padding Bottom", "default": 40
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Join The Club"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Subscribe to receive updates, access to exclusive deals, and more."
        },
        {
          "type": "text",
          "id": "placeholder_text",
          "label": "Input Placeholder",
          "default": "Email address"
        },
        {
          "type": "text",
          "id": "success_text",
          "label": "Success Message",
          "default": "Thank you for subscribing!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Footer",
      "blocks": [
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
