    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9fafb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Layout & Sizing"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        { "value": "full", "label": "Full Width (100%)" },
        { "value": "wide", "label": "Wide (1600px)" },
        { "value": "narrow", "label": "Narrow (1000px)" }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "page_margin",
      "min": 0, "max": 100, "step": 2, "unit": "px",
