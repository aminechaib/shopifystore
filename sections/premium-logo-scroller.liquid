{%- style -%}
  /* 1. Page Width Logic */
  {%- if section.settings.page_width == 'narrow' -%}
    {%- assign max_width = '1000px' -%}
  {%- elsif section.settings.page_width == 'wide' -%}
    {%- assign max_width = '1600px' -%}
  {%- else -%}
    {%- assign max_width = '100%' -%}
  {%- endif -%}

  /* 2. Apply Width, Horizontal Margin, and Vertical Spacing */
  #PremiumScroller-{{ section.id }} {
    max-width: {{ max_width }};
    width: calc(100% - {{ section.settings.page_margin | times: 2 }}px);
    margin-left: auto;
    margin-right: auto;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  @media screen and (max-width: 768px) {
    #PremiumScroller-{{ section.id }} {
      width: calc(100% - {{ section.settings.page_margin }}px);
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
      margin-top: {{ section.settings.margin_top | divided_by: 2 }}px;
      margin-bottom: {{ section.settings.margin_bottom | divided_by: 2 }}px;
    }
  }
{%- endstyle -%}

<section class="premium-scroller section-{{ section.id }}-padding" id="PremiumScroller-{{ section.id }}">
  <div class="ps-container">
    
    <!-- Animated Text Reveal Header -->
    <div class="ps-header">
      {% if section.settings.subheading != blank %}
        <div class="ps-text-mask">
          <span class="ps-subheading anim-reveal" style="color: {{ section.settings.text_color | color_modify: 'alpha', 0.6 }};">
            {{ section.settings.subheading }}
          </span>
        </div>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <div class="ps-text-mask">
          <h2 class="ps-heading anim-reveal" style="color: {{ section.settings.text_color }};">
            {{ section.settings.heading }}
          </h2>
        </div>
      {% endif %}
    </div>

    <!-- Infinite Scroller -->
    <div class="ps-marquee-wrapper">
      <!-- Left/Right Fade Gradients for smooth entry/exit -->
      <div class="ps-fade ps-fade-left" style="background: linear-gradient(to right, {{ section.settings.bg_color }} 0%, transparent 100%);"></div>
      <div class="ps-fade ps-fade-right" style="background: linear-gradient(to left, {{ section.settings.bg_color }} 0%, transparent 100%);"></div>

      <div class="ps-marquee" style="animation-duration: {{ section.settings.scroll_speed }}s;">
        <!-- Track 1 -->
        <div class="ps-marquee-track">
          {%- for block in section.blocks -%}
            <div class="ps-logo-item" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | img_url: '400x' }}" alt="Brand Logo" loading="lazy" class="ps-logo-img {% if section.settings.grayscale_hover %}grayscale-hover{% endif %}">
              {%- else -%}
                <div class="ps-placeholder">Logo</div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
        <!-- Track 2 (Duplicated for seamless loop) -->
        <div class="ps-marquee-track" aria-hidden="true">
          {%- for block in section.blocks -%}
            <div class="ps-logo-item">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | img_url: '400x' }}" alt="Brand Logo" loading="lazy" class="ps-logo-img {% if section.settings.grayscale_hover %}grayscale-hover{% endif %}">
              {%- else -%}
                <div class="ps-placeholder">Logo</div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* --- Premium Scroller CSS --- */
  .premium-scroller {
    font-family: 'Helvetica Neue', sans-serif;
    position: relative;
  }

  .ps-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Text Reveal Animations */
  .ps-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 0 2rem;
  }

  .ps-text-mask {
    overflow: hidden; 
    padding-bottom: 0.2rem;
  }

  .anim-reveal {
    display: block;
    transform: translateY(100%);
    opacity: 0;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease;
  }

  .anim-reveal.is-visible {
    transform: translateY(0);
    opacity: 1;
  }

  .ps-subheading {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .ps-heading {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.02em;
  }

  /* Infinite Marquee */
  .ps-marquee-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
  }

  .ps-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 150px;
    z-index: 2;
    pointer-events: none;
  }
  .ps-fade-left { left: 0; }
  .ps-fade-right { right: 0; }

  .ps-marquee {
    display: flex;
    width: max-content;
    animation-name: scroll-marquee;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .ps-marquee-track {
    display: flex;
    align-items: center;
    gap: 4rem;
    padding: 0 2rem;
  }

  .ps-logo-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 180px;
    height: 100px;
    background: #ffffff;
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    padding: 1.5rem;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }

  .ps-logo-item:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .ps-logo-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: filter 0.4s ease;
  }

  /* Grayscale to Color Hover Effect */
  .grayscale-hover {
    filter: grayscale(100%) opacity(0.6);
  }
  .ps-logo-item:hover .grayscale-hover {
    filter: grayscale(0%) opacity(1);
  }

  .ps-placeholder {
    font-weight: bold;
    color: #ccc;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @keyframes scroll-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .ps-heading { font-size: 2rem; }
    .ps-logo-item { width: 140px; height: 80px; }
    .ps-fade { width: 50px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.2
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if(entry.target.classList.contains('ps-heading')) {
            setTimeout(() => {
              entry.target.classList.add('is-visible');
            }, 150);
          } else {
            entry.target.classList.add('is-visible');
          }
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const revealElements = document.querySelectorAll('#PremiumScroller-{{ section.id }} .anim-reveal');
    revealElements.forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Animated Logo Scroller",
  "settings": [
    {
      "type": "header",
      "content": "Text Settings"
    },
    {
      "type": "text",
