<div style="padding: 40px 20px; max-width: 1200px; margin: 0 auto;">
  <h2 style="text-align: center; margin-bottom: 30px; text-transform: uppercase; letter-spacing: 2px;">
    {{ section.settings.heading }}
  </h2>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
    
    {%- assign selected_collection = collections[section.settings.collection] -%}
    
    {%- for product in selected_collection.products limit: section.settings.product_limit -%}
      <a href="{{ product.url }}" style="text-decoration: none; color: #000; display: block; group;">
        
        <!-- Product Image -->
        <div style="background: #f4f4f4; aspect-ratio: 3/4; overflow: hidden; margin-bottom: 12px;">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title }}" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;">
          {% else %}
            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #eee;">No Image</div>
          {% endif %}
        </div>

        <!-- Product Info -->
        <div style="display: flex; justify-content: space-between; font-size: 14px; font-weight: 700; text-transform: uppercase;">
          <span>{{ product.title }}</span>
          <span>{{ product.price | money }}</span>
        </div>
        
      </a>
    {%- else -%}
      <p style="text-align: center; grid-column: 1 / -1;">No products found. Please select a collection in the theme editor.</p>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Custom Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Number of products to show"
    }
  ],
  "presets": [
    {
      "name": "Custom Product Grid"
    }
  ]
}
{% endschema %}
