{%- style -%}
  #PremiumHero-{{ section.id }} {
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    --hero-height: {{ section.settings.section_height }};
    --overlay-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    --text-color: {{ section.settings.text_color }};
  }

  /* Blurred Reflection Effect */
  {% if section.settings.show_blurred_reflection %}
    #PremiumHero-{{ section.id }} .ph-blurred-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      filter: blur(30px) saturate(1.5);
      transform: scale(1.1);
      opacity: 0.6;
      pointer-events: none;
    }
    #PremiumHero-{{ section.id }} .ph-main-media-container {
      width: 90%;
      height: 90%;
      margin: 0 auto;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0,0,0,0.2);
    }
  {% else %}
    #PremiumHero-{{ section.id }} .ph-main-media-container {
      width: 100%;
      height: 100%;
    }
  {% endif %}
{%- endstyle -%}

<section id="PremiumHero-{{ section.id }}" class="premium-hero-advanced">
  
  <!-- Blurred Reflection Background (Optional) -->
  {% if section.settings.show_blurred_reflection %}
    <div class="ph-blurred-bg desktop-media">
      {% if section.settings.desktop_image != blank %}
        <img src="{{ section.settings.desktop_image | img_url: '100x' }}" alt="" class="ph-media-fit">
      {% endif %}
    </div>
    <div class="ph-blurred-bg mobile-media">
      {% if section.settings.mobile_image != blank %}
        <img src="{{ section.settings.mobile_image | img_url: '100x' }}" alt="" class="ph-media-fit">
      {% elsif section.settings.desktop_image != blank %}
        <img src="{{ section.settings.desktop_image | img_url: '100x' }}" alt="" class="ph-media-fit">
      {% endif %}
    </div>
  {% endif %}

  <!-- Main Media Container -->
  <div class="ph-main-media-container">
    
    <!-- Desktop Media -->
    <div class="ph-media-wrapper desktop-media">
      {% if section.settings.desktop_video != blank %}
        <video autoplay loop muted playsinline class="ph-media-fit">
          <source src="{{ section.settings.desktop_video }}" type="video/mp4">
        </video>
      {% elsif section.settings.desktop_image != blank %}
        <img src="{{ section.settings.desktop_image | img_url: 'master' }}" alt="{{ section.settings.heading }}" class="ph-media-fit">
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'ph-media-fit placeholder-svg' }}
      {% endif %}
    </div>

    <!-- Mobile Media -->
    <div class="ph-media-wrapper mobile-media">
      {% if section.settings.mobile_video != blank %}
        <video autoplay loop muted playsinline class="ph-media-fit">
          <source src="{{ section.settings.mobile_video }}" type="video/mp4">
        </video>
      {% elsif section.settings.mobile_image != blank %}
        <img src="{{ section.settings.mobile_image | img_url: 'master' }}" alt="{{ section.settings.heading }}" class="ph-media-fit">
      {% elsif section.settings.desktop_video != blank %}
        <video autoplay loop muted playsinline class="ph-media-fit">
          <source src="{{ section.settings.desktop_video }}" type="video/mp4">
        </video>
      {% elsif section.settings.desktop_image != blank %}
        <img src="{{ section.settings.desktop_image | img_url: 'master' }}" alt="{{ section.settings.heading }}" class="ph-media-fit">
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'ph-media-fit placeholder-svg' }}
      {% endif %}
    </div>

    <!-- Dark Overlay -->
    <div class="ph-overlay"></div>

    <!-- Content -->
    <div class="ph-content-wrapper" style="align-items: {{ section.settings.vertical_alignment }}; justify-content: {{ section.settings.horizontal_alignment }}; text-align: {{ section.settings.text_alignment }};">
      <div class="ph-content">
        
        {% if section.settings.subheading != blank %}
          <div class="ph-text-mask">
            <span class="ph-subheading reveal-text">{{ section.settings.subheading }}</span>
          </div>
        {% endif %}
        
        {% if section.settings.heading != blank %}
          <div class="ph-text-mask">
            <h1 class="ph-heading reveal-text">{{ section.settings.heading }}</h1>
          </div>
        {% endif %}
        
        {% if section.settings.text != blank %}
          <div class="ph-text-mask">
            <p class="ph-desc reveal-text">{{ section.settings.text }}</p>
          </div>
        {% endif %}

        <div class="ph-buttons">
          {% if section.settings.btn_1_label != blank %}
            <div class="ph-text-mask">
              <a href="{{ section.settings.btn_1_link }}" class="ph-btn ph-btn-primary reveal-text">{{ section.settings.btn_1_label }}</a>
            </div>
          {% endif %}
          {% if section.settings.btn_2_label != blank %}
            <div class="ph-text-mask">
              <a href="{{ section.settings.btn_2_link }}" class="ph-btn ph-btn-secondary reveal-text">{{ section.settings.btn_2_label }}</a>
            </div>
          {% endif %}
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  /* --- Advanced Hero CSS --- */
  .premium-hero-advanced {
    position: relative;
    width: 100%;
    height: var(--hero-height);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
    font-family: 'Helvetica Neue', sans-serif;
  }

  .ph-main-media-container {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.5s ease;
  }

  .ph-media-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .ph-media-fit {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .placeholder-svg { background-color: #222; fill: #444; }

  .ph-overlay {
    position: absolute;
    inset: 0;
    background: var(--overlay-color);
    z-index: 2;
  }

  /* Desktop vs Mobile Media Logic */
  .mobile-media { display: none; }
  @media (max-width: 768px) {
    .desktop-media { display: none; }
    .mobile-media { display: block; }
  }

  /* Content */
  .ph-content-wrapper {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    padding: 4rem;
    width: 100%;
    height: 100%;
  }

  .ph-content {
    max-width: 800px;
  }

  .ph-text-mask {
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .ph-subheading {
    display: block;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 600;
    color: var(--text-color);
  }

  .ph-heading {
    font-size: 4.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--text-color);
  }

  .ph-desc {
    font-size: 1.2rem;
    color: var(--text-color);
    opacity: 0.9;
    margin: 0;
    line-height: 1.5;
  }

  /* Buttons */
  .ph-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .ph-btn {
    display: inline-block;
    padding: 1.2rem 3rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: all 0.4s ease;
  }

  .ph-btn-primary {
    background: var(--text-color);
    color: #000; /* Inverts to background */
  }
  .ph-btn-primary:hover {
    background: transparent;
    color: var(--text-color);
    box-shadow: inset 0 0 0 1px var(--text-color);
  }

  .ph-btn-secondary {
    background: transparent;
    color: var(--text-color);
    box-shadow: inset 0 0 0 1px var(--text-color);
  }
  .ph-btn-secondary:hover {
    background: var(--text-color);
    color: #000;
  }

  /* Animations */
  .reveal-text {
    display: block;
    transform: translateY(100%);
    opacity: 0;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 1.2s ease;
  }

  .premium-hero-advanced.is-loaded .reveal-text {
    transform: translateY(0);
    opacity: 1;
  }

  /* Staggered Delays */
  .premium-hero-advanced.is-loaded .ph-subheading { transition-delay: 0.1s; }
  .premium-hero-advanced.is-loaded .ph-heading { transition-delay: 0.3s; }
  .premium-hero-advanced.is-loaded .ph-desc { transition-delay: 0.5s; }
  .premium-hero-advanced.is-loaded .ph-btn-primary { transition-delay: 0.7s; }
  .premium-hero-advanced.is-loaded .ph-btn-secondary { transition-delay: 0.8s; }

  /* Responsive */
  @media (max-width: 768px) {
    .ph-content-wrapper { padding: 2rem; }
    .ph-heading { font-size: 3rem; }
    .ph-desc { font-size: 1rem; }
    .ph-buttons { flex-direction: column; width: 100%; }
    .ph-btn { width: 100%; text-align: center; }
    
    {% if section.settings.show_blurred_reflection %}
      #PremiumHero-{{ section.id }} .ph-main-media-container {
        width: 85%;
        height: 85%;
        border-radius: 16px;
      }
    {% endif %}
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.getElementById('PremiumHero-{{ section.id }}');
    if(hero) {
      setTimeout(() => {
        hero.classList.add('is-loaded');
      }, 100);
    }
  });
</script>

{% schema %}
{
  "name": "Premium Hero (Advanced)",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Media"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "text",
      "id": "desktop_video",
      "label": "Desktop Video URL (MP4)",
      "info": "Upload an MP4 to Shopify Files and paste the link here. Overrides image."
    },
    {
      "type": "header",
      "content": "Mobile Media (Optional)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image",
      "info": "If left blank, desktop media will be used."
    },
    {
      "type": "text",
      "id": "mobile_video",
      "label": "Mobile Video URL (MP4)",
      "info": "Overrides mobile image."
    },
    {
      "type": "header",
      "content": "Special Effects"
    },
    {
      "type": "checkbox",
      "id": "show_blurred_reflection",
      "label": "Enable Blurred Reflection Effect",
      "info": "Shrinks the main image slightly and creates a beautiful blurred glowing background behind it.",
      "default": false
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0, "max": 100, "step": 5, "default": 30,
      "label": "Dark Overlay Opacity (%)"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "New Arrival"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Fall Collection"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Discover the latest premium pieces designed for the modern wardrobe."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn_1_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn_2_label",
      "label": "Secondary Button Label",
      "default": "View Lookbook"
    },
    {
      "type": "url",
      "id": "btn_2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Layout & Alignment"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height",
      "options": [
        { "value": "100vh", "label": "Full Screen" },
        { "value": "80vh", "label": "Large" },
        { "value": "60vh", "label": "Medium" }
      ],
      "default": "100vh"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Horizontal Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Margin Top", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Margin Bottom", "default": 0
    }
  ],
  "presets": [
    {
      "name": "Premium Hero (Advanced)"
    }
  ]
}
{% endschema %}
