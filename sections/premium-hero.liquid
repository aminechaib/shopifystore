{%- style -%}
  /* 1. Page Width Logic */
  {%- if section.settings.page_width == 'narrow' -%}
    {%- assign max_width = '1000px' -%}
  {%- elsif section.settings.page_width == 'wide' -%}
    {%- assign max_width = '1600px' -%}
  {%- else -%}
    {%- assign max_width = '100%' -%}
  {%- endif -%}

  /* 2. Apply Width, Horizontal Margin, and Vertical Spacing */
  #PremiumHero-{{ section.id }} {
    max-width: {{ max_width }};
    /* Calculates 100% width minus the left and right margins */
    width: calc(100% - {{ section.settings.page_margin | times: 2 }}px);
    margin-left: auto;
    margin-right: auto;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  @media screen and (max-width: 768px) {
    #PremiumHero-{{ section.id }} {
      /* Slightly smaller horizontal margins on mobile */
      width: calc(100% - {{ section.settings.page_margin }}px);
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
      margin-top: {{ section.settings.margin_top | divided_by: 2 }}px;
      margin-bottom: {{ section.settings.margin_bottom | divided_by: 2 }}px;
    }
  }
{%- endstyle -%}

<section class="premium-hero section-{{ section.id }}-padding" id="PremiumHero-{{ section.id }}">
  
  <!-- Background Media with Parallax -->
  <div class="phero-bg" id="ParallaxBg-{{ section.id }}">
    {% if section.settings.video_url != blank %}
      <video autoplay loop muted playsinline class="phero-media">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% elsif section.settings.image != blank %}
      <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading }}" class="phero-media">
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'phero-media placeholder-svg' }}
    {% endif %}
    
    <!-- Dark Overlay for Text Readability -->
    <div class="phero-overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  </div>

  <!-- Content -->
  <div class="phero-content">
    
    {% if section.settings.subheading != blank %}
      <div class="phero-text-mask">
        <p class="phero-subheading reveal-text">{{ section.settings.subheading }}</p>
      </div>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <div class="phero-text-mask">
        <h1 class="phero-heading reveal-text">{{ section.settings.heading }}</h1>
      </div>
    {% endif %}

    {% if section.settings.btn_label != blank %}
      <div class="phero-text-mask">
        <a href="{{ section.settings.btn_link }}" class="phero-btn reveal-text">
          <span class="btn-text">{{ section.settings.btn_label }}</span>
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  /* --- Premium Hero CSS --- */
  .premium-hero {
    position: relative;
    height: 100vh; /* Full screen height */
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: #111;
  }

  /* Parallax Background */
  .phero-bg {
    position: absolute;
    top: -15%; 
    left: 0;
    width: 100%;
    height: 130%; 
    z-index: 1;
    will-change: transform;
  }

  .phero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder-svg {
    background-color: #333;
    fill: #555;
  }

  .phero-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: #000000;
  }

  /* Content & Typography */
  .phero-content {
    position: relative;
    z-index: 2;
    color: #ffffff;
    max-width: 900px;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .phero-text-mask {
    overflow: hidden; 
    margin-bottom: 1rem;
  }

  .phero-subheading {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    margin: 0 0 1rem 0;
    font-weight: 500;
  }

  .phero-heading {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 5.5rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1;
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* Premium Button */
  .phero-btn {
    display: inline-block;
    margin-top: 2.5rem;
    padding: 1.2rem 3.5rem;
    background: #ffffff;
    color: #000000;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    font-size: 0.85rem;
    font-family: 'Helvetica Neue', sans-serif;
    position: relative;
    overflow: hidden;
    transition: color 0.4s ease;
  }

  .phero-btn::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: #000000;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: 1;
  }

  .phero-btn:hover::before {
    transform: scaleY(1);
  }

  .phero-btn:hover {
    color: #ffffff;
  }

  .phero-btn .btn-text {
    position: relative;
    z-index: 2;
  }

  /* --- Animations --- */
  .reveal-text {
    transform: translateY(100%);
    opacity: 0;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 1.2s ease;
  }

  .premium-hero.is-loaded .reveal-text {
    transform: translateY(0);
    opacity: 1;
  }

  .premium-hero.is-loaded .phero-subheading { transition-delay: 0.2s; }
  .premium-hero.is-loaded .phero-heading { transition-delay: 0.4s; }
  .premium-hero.is-loaded .phero-btn { transition-delay: 0.6s; }

  /* Responsive */
  @media (max-width: 768px) {
    .phero-heading { font-size: 3rem; }
    .phero-subheading { font-size: 0.75rem; }
    .phero-btn { padding: 1rem 2.5rem; margin-top: 1.5rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.getElementById('PremiumHero-{{ section.id }}');
    const bg = document.getElementById('ParallaxBg-{{ section.id }}');

    if(hero) {
      setTimeout(() => {
        hero.classList.add('is-loaded');
      }, 150); 

      window.addEventListener('scroll', () => {
        const scrollPosition = window.pageYOffset;
        if(scrollPosition <= window.innerHeight) {
          bg.style.transform = `translateY(${scrollPosition * 0.4}px)`;
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Premium Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Background Video URL (MP4)",
      "info": "Upload an MP4 to Shopify Files and paste the link here. Overrides image."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30,
      "label": "Dark Overlay Opacity (%)"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "New Season"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Autumn Collection"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Layout & Sizing"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        { "value": "full", "label": "Full Width (100%)" },
        { "value": "wide", "label": "Wide (1600px)" },
        { "value": "narrow", "label": "Narrow (1000px)" }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "page_margin",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Page Margin (Left/Right)",
      "default": 0,
      "info": "Adds empty space on the left and right sides of the section."
    },
    {
      "type": "header",
      "content": "Spacing (Top & Bottom)"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Margin Top", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Margin Bottom", "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Padding Top", "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Padding Bottom", "default": 0
    }
  ],
  "presets": [
    {
      "name": "Premium Hero"
    }
  ]
}
{% endschema %}
