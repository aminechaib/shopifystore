{%- style -%}
  {%- if section.settings.page_width == 'full' -%}
    {%- assign max_w = '100%' -%}
  {%- elsif section.settings.page_width == 'wide' -%}
    {%- assign max_w = '1600px' -%}
  {%- else -%}
    {%- assign max_w = '1200px' -%}
  {%- endif -%}

  #PremiumGrid-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  #PremiumGrid-{{ section.id }} .pgrid-container {
    max-width: {{ max_w }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.edge_spacing }}px {{ section.settings.padding_bottom }}px {{ section.settings.edge_spacing }}px;
    margin: 0 auto;
  }

  @media screen and (max-width: 768px) {
    #PremiumGrid-{{ section.id }} .pgrid-container {
      padding: calc({{ section.settings.padding_top }}px / 2) 1.5rem calc({{ section.settings.padding_bottom }}px / 2) 1.5rem;
    }
  }
{%- endstyle -%}

<section class="premium-grid" id="PremiumGrid-{{ section.id }}">
  <div class="pgrid-container">
    
    <!-- Section Header -->
    <div class="pgrid-header" style="text-align: {{ section.settings.text_alignment }};">
      {% if section.settings.heading != blank %}
        <h2 class="pgrid-title" style="color: {{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.view_all_link != blank %}
        <a href="{{ section.settings.view_all_link }}" class="pgrid-view-all" style="color: {{ section.settings.accent_color }};">
          {{ section.settings.view_all_text }}
        </a>
      {% endif %}
    </div>

    <!-- Product Grid -->
    <div class="pgrid-wrapper">
      {% assign collection = collections[section.settings.collection] %}
      
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: section.settings.products_to_show %}
          <div class="pgrid-item reveal-on-scroll" style="--anim-delay: {{ forloop.index | times: 0.1 }}s;">
            <a href="{{ product.url }}" class="pgrid-card">
              
              <!-- Image Wrapper (Hover Reveal) -->
              <div class="pgrid-image-wrap">
                <img src="{{ product.featured_image | img_url: '600x800', crop: 'center' }}" alt="{{ product.title }}" class="pgrid-img-primary" loading="lazy">
                
                {% if product.images.size > 1 %}
                  <img src="{{ product.images[1] | img_url: '600x800', crop: 'center' }}" alt="{{ product.title }}" class="pgrid-img-secondary" loading="lazy">
                {% endif %}
                
                <div class="pgrid-badge" style="background: {{ section.settings.accent_color }}; color: #fff;">Voir Détails</div>
              </div>

              <!-- Product Info -->
              <div class="pgrid-info" style="color: {{ section.settings.text_color }};">
                <h3 class="pgrid-product-title">{{ product.title }}</h3>
                <p class="pgrid-product-price">{{ product.price | money }}</p>
              </div>
              
            </a>
          </div>
        {% endfor %}
      {% else %}
        <!-- Placeholder for Editor -->
        {% for i in (1..4) %}
          <div class="pgrid-item reveal-on-scroll" style="--anim-delay: {{ forloop.index | times: 0.1 }}s;">
            <div class="pgrid-card">
              <div class="pgrid-image-wrap">
                {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="pgrid-info" style="color: {{ section.settings.text_color }};">
                <h3 class="pgrid-product-title">Pièce Originale {{ i }}</h3>
                <p class="pgrid-product-price">DZD 4500.00</p>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</section>

<style>
  .premium-grid { width: 100%; font-family: 'Helvetica Neue', sans-serif; overflow: hidden; }
  .pgrid-header { margin-bottom: 3rem; display: flex; flex-direction: column; gap: 1rem; }
  .pgrid-title { font-size: 2.5rem; font-weight: 700; margin: 0; letter-spacing: -0.02em; }
  .pgrid-view-all { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; text-decoration: none; font-weight: 600; display: inline-block; position: relative; align-self: inherit; }
  .pgrid-view-all::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 100%; height: 2px; background: currentColor; transform: scaleX(0); transform-origin: right; transition: transform 0.4s ease; }
  .pgrid-view-all:hover::after { transform: scaleX(1); transform-origin: left; }
  
  .pgrid-wrapper { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .pgrid-card { text-decoration: none; display: block; group: product; }
  .pgrid-image-wrap { position: relative; width: 100%; aspect-ratio: 3 / 4; overflow: hidden; background: #f4f4f4; margin-bottom: 1.5rem; border-radius: 1rem; }
  .pgrid-img-primary, .pgrid-img-secondary, .placeholder-svg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: opacity 0.6s ease, transform 1.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .pgrid-img-secondary { opacity: 0; z-index: 2; }
  
  .pgrid-card:hover .pgrid-img-primary { transform: scale(1.05); }
  .pgrid-card:hover .pgrid-img-secondary { opacity: 1; transform: scale(1.05); }
  
  .pgrid-badge { position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%) translateY(20px); padding: 0.8rem 1.5rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; opacity: 0; z-index: 3; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); border-radius: 50px; white-space: nowrap; }
  .pgrid-card:hover .pgrid-badge { opacity: 1; transform: translateX(-50%) translateY(0); }
  
  .pgrid-info { text-align: center; }
  .pgrid-product-title { font-size: 1.1rem; font-weight: 600; margin: 0 0 0.5rem 0; }
  .pgrid-product-price { font-size: 1rem; margin: 0; opacity: 0.8; font-weight: 500; }
  
  .reveal-on-scroll { opacity: 0; transform: translateY(40px); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1); transition-delay: var(--anim-delay); }
  .reveal-on-scroll.is-visible { opacity: 1; transform: translateY(0); }
  
  @media (max-width: 768px) {
    .pgrid-wrapper { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .pgrid-title { font-size: 2rem; }
    .pgrid-badge { display: none; }
    .pgrid-image-wrap { border-radius: 0.5rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = { root: null, rootMargin: '0px', threshold: 0.15 };
    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);
    const revealElements = document.querySelectorAll('#PremiumGrid-{{ section.id }} .reveal-on-scroll');
    revealElements.forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Premium Featured Grid",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nos Produits"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "Voir Tout"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2, "max": 12, "step": 1, "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#024158"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#B80000"
    },
    {
      "type": "header",
      "content": "Layout & Sizing"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        { "value": "full", "label": "Full Width (100%)" },
        { "value": "wide", "label": "Wide (1600px)" },
        { "value": "standard", "label": "Standard (1200px)" }
      ],
      "default": "wide"
    },
    {
      "type": "range",
      "id": "edge_spacing",
      "min": 0, "max": 100, "step": 2, "unit": "px",
      "label": "Distance from screen edges",
      "default": 40
    },
    {
      "type": "header",
      "content": "Spacing (Top & Bottom)"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Margin Top", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Margin Bottom", "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Padding Top", "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 5, "unit": "px",
      "label": "Padding Bottom", "default": 80
    }
  ],
  "presets": [
    {
      "name": "Premium Featured Grid"
    }
  ]
}
{% endschema %}
