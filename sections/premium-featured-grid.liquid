{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
      margin-top: {{ section.settings.margin_top | divided_by: 2 }}px;
      margin-bottom: {{ section.settings.margin_bottom | divided_by: 2 }}px;
    }
  }
{%- endstyle -%}

<section class="premium-grid section-{{ section.id }}-padding" id="PremiumGrid-{{ section.id }}">
  <div class="pgrid-container">
    
    <!-- Section Header -->
    <div class="pgrid-header" style="text-align: {{ section.settings.text_alignment }};">
      {% if section.settings.heading != blank %}
        <h2 class="pgrid-title" style="color: {{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.view_all_link != blank %}
        <a href="{{ section.settings.view_all_link }}" class="pgrid-view-all" style="color: {{ section.settings.text_color }};">
          {{ section.settings.view_all_text }}
        </a>
      {% endif %}
    </div>

    <!-- Product Grid -->
    <div class="pgrid-wrapper">
      {% assign collection = collections[section.settings.collection] %}
      
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: section.settings.products_to_show %}
          <div class="pgrid-item reveal-on-scroll" style="--anim-delay: {{ forloop.index | times: 0.1 }}s;">
            <a href="{{ product.url }}" class="pgrid-card">
              
              <!-- Image Wrapper (Hover Reveal) -->
              <div class="pgrid-image-wrap">
                <img src="{{ product.featured_image | img_url: '600x800', crop: 'center' }}" alt="{{ product.title }}" class="pgrid-img-primary" loading="lazy">
                
                {% if product.images.size > 1 %}
                  <img src="{{ product.images[1] | img_url: '600x800', crop: 'center' }}" alt="{{ product.title }}" class="pgrid-img-secondary" loading="lazy">
                {% endif %}
                
                <!-- Quick Add Badge (Optional Visual) -->
                <div class="pgrid-badge">View Details</div>
              </div>

              <!-- Product Info -->
              <div class="pgrid-info" style="color: {{ section.settings.text_color }};">
                <h3 class="pgrid-product-title">{{ product.title }}</h3>
                <p class="pgrid-product-price">{{ product.price | money }}</p>
              </div>
              
            </a>
          </div>
        {% endfor %}
      {% else %}
        <!-- Placeholder for Editor -->
        {% for i in (1..3) %}
          <div class="pgrid-item reveal-on-scroll" style="--anim-delay: {{ forloop.index | times: 0.1 }}s;">
            <div class="pgrid-card">
              <div class="pgrid-image-wrap">
                {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="pgrid-info" style="color: {{ section.settings.text_color }};">
                <h3 class="pgrid-product-title">Premium Garment {{ i }}</h3>
                <p class="pgrid-product-price">$120.00</p>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</section>

<style>
  /* --- Premium Grid CSS --- */
  .premium-grid {
    width: 100%;
    font-family: 'Helvetica Neue', sans-serif;
    overflow: hidden;
  }

  .pgrid-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .pgrid-header {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .pgrid-title {
    font-size: 2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .pgrid-view-all {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    font-weight: 500;
    display: inline-block;
    position: relative;
    align-self: inherit;
  }

  .pgrid-view-all::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0; width: 100%; height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s ease;
  }

  .pgrid-view-all:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Grid Layout */
  .pgrid-wrapper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  /* Product Card */
  .pgrid-card {
    text-decoration: none;
    display: block;
    group: product;
  }

  .pgrid-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4; /* High-end fashion aspect ratio */
    overflow: hidden;
    background: #f4f4f4;
    margin-bottom: 1.5rem;
  }

  .pgrid-img-primary, .pgrid-img-secondary, .placeholder-svg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover;
    transition: opacity 0.6s ease, transform 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pgrid-img-secondary {
    opacity: 0;
    z-index: 2;
  }

  /* Hover Effects */
  .pgrid-card:hover .pgrid-img-primary {
    transform: scale(1.05);
  }

  .pgrid-card:hover .pgrid-img-secondary {
    opacity: 1;
    transform: scale(1.05);
  }

  .pgrid-badge {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #fff;
    color: #000;
    padding: 0.8rem 1.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    opacity: 0;
    z-index: 3;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pgrid-card:hover .pgrid-badge {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Product Info */
  .pgrid-info {
    text-align: center;
  }

  .pgrid-product-title {
    font-size: 0.95rem;
    font-weight: 500;
    margin: 0 0 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pgrid-product-price {
    font-size: 0.9rem;
    margin: 0;
    opacity: 0.8;
  }

  /* Scroll Animation */
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--anim-delay);
  }

  .reveal-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .pgrid-wrapper {
      grid-template-columns: repeat(2, 1fr); /* 2 columns on mobile */
      gap: 1rem;
    }
    .pgrid-container { padding: 0 1rem; }
    .pgrid-title { font-size: 1.5rem; }
    .pgrid-badge { display: none; } /* Hide badge on mobile */
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Intersection Observer for Scroll Animations
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target); // Only animate once
        }
      });
    }, observerOptions);

    const revealElements = document.querySelectorAll('.reveal-on-scroll');
    revealElements.forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Premium Featured Grid",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending Now"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "Discover All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing (Margins & Padding)"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Premium Featured Grid"
    }
  ]
}
{% endschema %}
